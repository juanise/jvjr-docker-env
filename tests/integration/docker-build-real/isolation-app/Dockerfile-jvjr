# =============================================================================
# STAGE 1 — Build
# Compiles the frontend application inside a Node.js environment.
# The resulting /app/dist directory is the only artifact passed to Stage 2.
# =============================================================================
FROM node:24-alpine AS build-stage

WORKDIR /app

# Copy dependency manifests first to leverage Docker layer caching.
# npm install only re-runs when package.json or package-lock.json change.
COPY package*json ./

# Optional: custom registry/auth config managed by jvjr --start.
# These lines are removed automatically by jvjr if the files do not exist
# in the project root, keeping the image clean.

# Copy .env so jvjr --build (called inside npm run build) can generate
# jvjr-env.json with the variable mapping for runtime substitution.
COPY .env .

RUN npm install

# Copy the rest of the source after npm install to preserve cache for deps.
COPY . .

# Produces /app/dist (static assets) and /app/jvjr-env.json (var mapping).
RUN npm run build

# =============================================================================
# STAGE 2 — Production
# Serves the compiled assets with Nginx.
# Only the files strictly needed at runtime are included — no Node.js, no
# source code, no dev dependencies. Final image stays small and secure.
# =============================================================================
FROM nginx:1.27-alpine AS production-stage

# Copy compiled frontend assets from the build stage into the nginx serving directory.
COPY --from=build-stage /app/dist /usr/share/nginx/html

# Protected source copy — never modified at runtime.
# The entrypoint restores /usr/share/nginx/html from here on every container
# start, making PUBLIC_PATH changes and container restarts fully idempotent.
COPY --from=build-stage /app/dist /app-source

# Copy the jvjr runtime scripts.
# jvjr-entrypoint.sh: substitutes env vars into the compiled JS files on startup.
# jvjr-env.json:      maps short keys to their full env var names (e.g. API_URL -> $VUE_APP_API_URL).
COPY --from=build-stage /app/jvjr-entrypoint.sh /
COPY --from=build-stage /app/jvjr-env.json /

RUN chmod +x /jvjr-entrypoint.sh

# Nginx listens on port 80 (HTTP).
EXPOSE 80

# ENTRYPOINT arguments passed to jvjr-entrypoint.sh:
#   $1 — absolute path to the compiled JS directory inside nginx html root
#   $2 — JS bundle filename prefix (matches files like app.<hash>.js)
# CMD provides the remaining arguments: "$@" in the entrypoint executes nginx.
ENTRYPOINT [ "/jvjr-entrypoint.sh", "/usr/share/nginx/html/js", "app" ]
CMD ["nginx", "-g", "daemon off;"]