{
  "name": "jvjr-docker-env",
  "version": "2.0.0",
  "description": "Environment variables on docker with Vue and React",
  "type": "module",
  "main": "index.js",
  "typings": "index.d.ts",
  "scripts": {
    "install": "node scripts/start.js",
    "uninstall": "node scripts/uninstall.js",
    "build": "jvjr --build",
    "jvjr-build": "jvjr --build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "engines": {
    "node": ">=18 <25"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "templates/",
    "index.js",
    "index.d.ts",
    "EnvProvider.js",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "@juanise/jvjr": "bin/jvjr",
    "jvjr": "bin/jvjr"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juanise/jvjr-docker-env.git"
  },
  "bugs": "https://github.com/juanise/jvjr-docker-env/issues",
  "keywords": [
    "Docker",
    "environment",
    "variables",
    "Vue",
    "React"
  ],
  "author": "Juan Nicolau Sepúlveda",
  "license": "MIT",
  "dependencies": {
    "arg": "^5.0.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "ncp": "^2.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^29.7.0"
  }
}
